# ── Database ────────────────────────────────────────────────────────────────
# Leave commented out to use SQLite (default, no setup required).
# Uncomment and fill in for PostgreSQL:
# DATABASE_URL=postgresql://roadguard:roadguard@localhost:5432/roadguard

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:8501
EVIDENCE_DIR=evidence

# ── Model paths (relative to project root) ──────────────────────────────────
ACCIDENT_MODEL=models/acc_detect.pt
VEHICLE_MODEL=models/yolov8n.pt
PLATE_MODEL=models/yolo26n.pt
DEBLUR_MODEL=models/fpn_inception.h5

# ── Detection thresholds ─────────────────────────────────────────────────────
ACCIDENT_CONF=0.50
VEHICLE_CONF=0.40
PLATE_CONF=0.25

# ── GPU / Performance ────────────────────────────────────────────────────
# DEVICE=             # '' = auto-detect, 'cuda:0' = force GPU, 'cpu' = force CPU
HALF_PRECISION=1      # 1 = FP16 on GPU (~2× faster), 0 = FP32
INFER_IMGSZ=640       # YOLO inference resolution (lower = faster: 416, 320)
OCR_GPU=1             # 1 = GPU-accelerated EasyOCR, 0 = CPU
DEBLUR_GPU=1          # 1 = GPU-accelerated DeblurGAN, 0 = CPU

# ── Hit-and-Run settings ──────────────────────────────────────────────────────
HIT_RUN_TIMEOUT=10.0        # seconds after accident to monitor
HIT_RUN_RADIUS=200          # pixel radius of accident zone

# ── API retry (processor → backend) ─────────────────────────────────────────
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=2.0

# ── Twilio SMS (optional) ────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── SMTP Email (optional) ────────────────────────────────────────────────────
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# ── Emergency contacts (comma-separated, optional) ───────────────────────────
# EMERGENCY_PHONES=+911234567890,+911234567891
# EMERGENCY_EMAILS=police@city.gov,hospital@health.gov
